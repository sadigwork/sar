datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String @id @default(cuid())
  email     String @unique
  firstName String
  lastName  String
  password  String

  role         Role    @default(USER)
  isActive     Boolean @default(true)
  refreshToken String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile         Profile?
  applications    Application[]
  reviews         ApplicationReview[]
  documents       Document[]
  payments        Payment[]
  tokens          RefreshToken[]
  activities      ActivityLog[]
  notifications   Notification[]
  // مراجعات كمراجع
  documentReviews DocumentReview[]    @relation("UserDocumentReviews")
  profileReviews  ProfileReview[]     @relation("UserProfileReviews")
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique

  fullNameAr String
  fullNameEn String
  nationalId String  @unique
  phone      String?

  dateOfBirth DateTime?
  gender      String?
  address     String?
  city        String?
  country     String?

  avatar String?
  bio    String?

  status ProfileStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  educations   Education[]
  experiences  Experience[]
  documents    Document[]
  applications Application[]

  // مراجعات للبروفايل
  reviews ProfileReview[] @relation("ProfileReviews")
}

model Document {
  id            String  @id @default(uuid())
  userId        String
  profileId     String?
  applicationId String?

  type    DocumentType
  fileUrl String
  status  DocumentStatus @default(PENDING)

  createdAt DateTime @default(now())

  user        User             @relation(fields: [userId], references: [id])
  profile     Profile?         @relation(fields: [profileId], references: [id])
  reviews     DocumentReview[] @relation("DocumentReviews")
  application Application?     @relation(fields: [applicationId], references: [id])
}

model DocumentReview {
  id         String @id @default(cuid())
  documentId String
  reviewerId String

  document Document @relation(fields: [documentId], references: [id], name: "DocumentReviews")
  reviewer User     @relation(fields: [reviewerId], references: [id], name: "UserDocumentReviews")

  createdAt DateTime       @default(now())
  decision  ReviewDecision
  comment   String?
  stage     ReviewStage    @default(REGISTRAR_REVIEW)
}

model ProfileReview {
  id         String @id @default(cuid())
  profileId  String
  reviewerId String

  profile  Profile @relation(fields: [profileId], references: [id], name: "ProfileReviews")
  reviewer User    @relation(fields: [reviewerId], references: [id], name: "UserProfileReviews")

  createdAt DateTime       @default(now())
  decision  ReviewDecision
  comment   String?
  stage     ReviewStage    @default(REGISTRAR_REVIEW)
}

model Application {
  id        String @id @default(uuid())
  userId    String
  profileId String

  type         ApplicationType
  status       ApplicationStatus @default(DRAFT)
  currentStage ReviewStage?      @default(REGISTRAR_REVIEW)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  submittedAt DateTime?

  user    User    @relation(fields: [userId], references: [id])
  profile Profile @relation(fields: [profileId], references: [id])

  reviews   ApplicationReview[]
  documents Document[]
  payments  Payment[]
}

model ApplicationReview {
  id            String @id @default(uuid())
  applicationId String
  reviewerId    String

  role           Role
  stage          ReviewStage    @default(REGISTRAR_REVIEW)
  decision       ReviewDecision
  comment        String?
  isOverride     Boolean?       @default(false)
  overrideReason String?

  createdAt DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id])
  reviewer    User        @relation(fields: [reviewerId], references: [id])

  @@index([applicationId, stage])
}

model Payment {
  id String @id @default(uuid())

  userId        String
  applicationId String

  amount    Float
  currency  String
  method    PaymentMethod
  status    PaymentStatus
  reference String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  application Application @relation(fields: [applicationId], references: [id])
}

model Education {
  id        String @id @default(cuid())
  profileId String

  degree      String
  field       String
  institution String
  country     String
  year        Int

  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id])
}

model Experience {
  id        String @id @default(cuid())
  profileId String

  company   String
  position  String
  startDate DateTime
  endDate   DateTime?
  isCurrent Boolean   @default(false)

  years  Int
  months Int

  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id])
}

model ActivityLog {
  id String @id @default(uuid())

  userId   String?
  action   String
  entity   String
  entityId String?
  metadata Json?

  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model RefreshToken {
  id String @id @default(uuid())

  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?

  ip        String?
  userAgent String?

  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Notification {
  id     String @id @default(uuid())
  userId String

  title   String
  message String

  type NotificationType @default(INFO)
  isRead Boolean          @default(false)

  metadata  Json?
  entity   String?
  entityId String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Workflow {
  id   String @id @default(cuid())
  name String

  applicationType ApplicationType

  stages WorkflowStage[]

  createdAt DateTime @default(now())
}

model WorkflowStage {
  id         String @id @default(cuid())
  workflowId String

  name String
  code ReviewStage

  order Int

  requiredRole Role
  minApprovals Int  @default(1)

  workflow        Workflow             @relation(fields: [workflowId], references: [id])
  // العلاقات مع WorkflowTransition
  fromTransitions WorkflowTransition[] @relation("FromStage")
  toTransitions   WorkflowTransition[] @relation("ToStage")

  createdAt DateTime @default(now())
}

model WorkflowTransition {
  id String @id @default(cuid())

  fromStageId String
  toStageId   String?

  condition ReviewDecision
  fromStage WorkflowStage  @relation("FromStage", fields: [fromStageId], references: [id])
  toStage   WorkflowStage? @relation("ToStage", fields: [toStageId], references: [id])
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum ProfileStatus {
  DRAFT
  SUBMITTED
  REGISTRAR_REVIEW
  REVIEWER_REVIEW
  FINANCE_REVIEW
  ADMIN_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum ApplicationType {
  REGISTRATION
  RENEWAL
  UPGRADE
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  REGISTRAR_REVIEW
  REVIEWER_REVIEW
  PAYMENT_PENDING
  PAYMENT_VERIFIED
  FINANCE_APPROVAL
  ADMIN_REVIEW
  APPROVED
  REJECTED
}

enum ReviewStage {
  REGISTRAR_REVIEW
  REVIEWER_REVIEW
  FINANCE_REVIEW
  ADMIN_REVIEW
}

enum ReviewDecision {
  APPROVED
  REJECTED
  REQUEST_CHANGES
  PAYMENT_VERIFIED
}

enum DocumentType {
  DEGREE
  LICENSE
  NATIONAL_ID
  PHOTO
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  USER
  REGISTRAR
  REVIEWER
  ACCOUNTANT
  FINANCE_MANAGER
  ADMIN
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  ONLINE
}

enum PaymentStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}
