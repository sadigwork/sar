{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "cwd": "apps/api",
        "args": []
      },
      "configurations": {
        "development": {
          "args": ["--mode=development"]
        },
        "production": {
          "args": ["--mode=production"]
        }
      }
    },
    "seed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ts-node --project tsconfig.base.json libs/infrastructure/prisma/prisma/seed.ts"
      }
    },
    "seed:generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ts-node --project tsconfig.base.json libs/infrastructure/prisma/prisma/seed-generator.ts"
      }
    },
    "prisma-generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma generate --schema=libs/infrastructure/prisma/prisma/schema.prisma"
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "api:build:development"
      },
      "configurations": {
        "development": {
          "buildTarget": "api:build:development"
        },
        "production": {
          "buildTarget": "api:build:production"
        }
      }
    }
  }
}
